{
  "name": "xteink-server",
  "version": "0.1.0",
  "description": "TRMNL-compatible BYOS server for the xteink X4 e-ink display",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "npm run build && node --watch dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
