{
  "name": "xteink-server",
  "version": "0.1.0",
  "description": "TRMNL-compatible BYOS server for the xteink X4 e-ink display",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node --import tsx/esm src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^8",
    "better-sqlite3": "^11",
    "dotenv": "^16",
    "fastify": "^5",
    "fastify-plugin": "^5.1.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
