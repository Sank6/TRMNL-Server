# Server
PORT=3000
HOST=0.0.0.0
DASHBOARD_PORT=3001

# Must be the LAN IP/hostname visible to the xteink device
BASE_URL=http://192.168.1.100:3000

# SQLite file path (created automatically)
DB_PATH=./data/xteink.db

# Directory scanned for images to serve to the device
IMAGE_DIR=./public/images

# Global refresh interval for device polling, widget regeneration, and dashboard auto-refresh
REFRESH_RATE_SECONDS=60

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Weather widget — coordinates and display name
WEATHER_LAT=51.5074
WEATHER_LON=-0.1278
WEATHER_LOCATION=London

# Google Pollen API key (https://developers.google.com/maps/documentation/pollen)
GOOGLE_POLLEN_API_KEY=your-key-here

# Apple Shared Album — provide either the full URL or just the token
PHOTOS_SHARED_ALBUM_TOKEN=your-token-here
# PHOTOS_SHARED_ALBUM_URL=https://www.icloud.com/photos/...
