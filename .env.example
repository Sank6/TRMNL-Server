# Server
PORT=3000
HOST=0.0.0.0

# Must be the LAN IP/hostname visible to the xteink device
BASE_URL=http://192.168.1.100:3000

# SQLite file path (created automatically)
DB_PATH=./data/xteink.db

# Directory scanned for images to serve to the device
IMAGE_DIR=./public/images

# How often (seconds) to ask the device to poll (default 15 min)
DEFAULT_REFRESH_RATE=900

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
